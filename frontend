let micRestartCount=0;
let finalTranscript='';
let interimTranscript='';

function toggleMic(){
  if(!('webkitSpeechRecognition' in window||'SpeechRecognition' in window)){
    setW('Voice not supported. Use Google Chrome for best results.','err');return;
  }
  if(isRec){
    recognition&&recognition.stop();
    stopMicUI();return;
  }
  startMic();
}

function startMic(){
  micRestartCount=0;finalTranscript='';interimTranscript='';
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  recognition=new SR();
  recognition.lang=document.getElementById('voiceLang').value;
  recognition.continuous=true;       // keeps listening
  recognition.interimResults=true;   // shows live results
  recognition.maxAlternatives=1;

  recognition.onstart=()=>{
    isRec=true;
    document.getElementById('micBtn').classList.add('rec');
    document.getElementById('micLabel').textContent='🔴 Listening... speak your order';
    setW('Speak clearly — say items and quantities','info');
  };

  recognition.onresult=(e)=>{
    interimTranscript='';
    for(let i=e.resultIndex;i<e.results.length;i++){
      const t=e.results[i][0].transcript;
      if(e.results[i].isFinal){
        finalTranscript+=t+' ';
      } else {
        // Only accept interim if confidence is reasonable
        if(e.results[i][0].confidence>0.3||e.results[i][0].confidence===0){
          interimTranscript+=t;
        }
      }
    }
    document.getElementById('transcript').value=(finalTranscript+interimTranscript).trim();
  };

  recognition.onerror=(e)=>{
    if(e.error==='no-speech'){
      // auto-restart on silence
      if(micRestartCount<3){
        micRestartCount++;
        setW('No speech detected — still listening... ('+micRestartCount+'/3)','info');
        try{recognition.start();}catch(_){}
        return;
      }
    }
    if(e.error==='aborted')return;
    setW('Mic error: '+e.error+'. Please try again.','err');
    stopMicUI();
  };

  recognition.onend=()=>{
    if(isRec && micRestartCount<5){
      // auto-restart to keep listening
      micRestartCount++;
      try{recognition.start();return;}catch(_){}
    }
    stopMicUI();
  };

  try{recognition.start();}
  catch(e){setW('Could not start mic. Check browser permissions.','err');}
}


// ════════════════════════════════
//  CUSTOMER FLOW — CORRECT ORDER
//  1. confirmOrder → shows "waiting" screen + polls every 3s
//  2. Waiter accepts → customer sees "accepted" screen
//  3. Customer taps "Done Eating" → bill + payment screen
//  4. Customer pays → payment done screen
// ════════════════════════════════
var custPollInterval=null;
var custCurrentOrderId=null;

async function confirmOrder(){
  var items=Object.values(custCart);
  if(!items.length){alert('Please add items to your cart first.');return;}

  // Save order to pending orders
  var orderId='ORD-'+Date.now();
  custCurrentOrderId=orderId;

  // CRITICAL: fetch existing orders from Firebase first
  // so we don't overwrite other tables' orders
  var pending = await loadPendingOrders();
  if(!Array.isArray(pending)) pending = [];

  var order={
    id:orderId,
    table:custTableNo,
    customerName:custCustomerName,
    customerPhone:custPhone,
    items:items.map(function(i){return{name:i.name,price:i.price,qty:i.qty};}),
    time:new Date().toLocaleString('en-IN'),
    status:'pending'
  };
  pending.unshift(order);
  if(pending.length>50)pending.pop();
  await savePendingOrders(pending); // wait for save to complete
  logActivity('bill','Customer Order','Table '+custTableNo+' placed: '+items.map(function(i){return i.qty+'x '+i.name;}).join(', '),'🛒');

  // Hide menu, show waiting screen
  document.getElementById('custCartPanel').classList.remove('open');
  document.getElementById('custGrid').style.display='none';
  document.querySelector('.cust-voice-bar').style.display='none';
  document.getElementById('custCats').style.display='none';

  var t=ld('bb_tax',{cgst:2.5,sgst:2.5});
  var sub=items.reduce(function(s,i){return s+i.qty*i.price;},0);
  var gst=Math.round(sub*(parseFloat(t.cgst)+parseFloat(t.sgst)))/100;
  var grand=(sub+gst).toFixed(2);

  // Show waiting screen
  showCustScreen('screenWaiting');
  document.getElementById('waitingOrderSummary').innerHTML=
    '<div style="font-size:13px;font-weight:700;color:#fff;margin-bottom:8px">Your Order Summary</div>'
    +items.map(function(i){return '<div style="display:flex;justify-content:space-between;font-size:12px;padding:3px 0;color:rgba(255,255,255,.7)"><span>'+i.qty+'× '+i.name+'</span><span>₹'+i.qty*i.price+'</span></div>';}).join('')
    +'<div style="display:flex;justify-content:space-between;font-size:13px;font-weight:700;color:#5DCAA5;padding-top:8px;margin-top:6px;border-top:1px solid rgba(255,255,255,.1)"><span>Total</span><span>₹'+grand+'</span></div>';

  // Start polling for acceptance
  startCustPolling(orderId, grand);
}

function startCustPolling(orderId, grand){
  if(custPollInterval)clearInterval(custPollInterval);
  custPollInterval=setInterval(async function(){
    var pending=await loadPendingOrders();
    var order=pending.find(function(o){return o.id===orderId;});
    if(order&&order.status==='accepted'){
      clearInterval(custPollInterval);
      showOrderAccepted(order, grand);
    }
  },3000);
}

function showOrderAccepted(order, grand){
  showCustScreen('screenAccepted');
  var items=order.items||[];
  document.getElementById('acceptedOrderSummary').innerHTML=
    '<div style="font-size:13px;font-weight:700;color:#5DCAA5;margin-bottom:8px">✅ Confirmed by Waiter</div>'
    +items.map(function(i){return '<div style="display:flex;justify-content:space-between;font-size:12px;padding:3px 0;color:rgba(255,255,255,.7)"><span>'+i.qty+'× '+i.name+'</span><span>₹'+i.qty*i.price+'</span></div>';}).join('')
    +'<div style="display:flex;justify-content:space-between;font-size:13px;font-weight:700;color:#fff;padding-top:8px;margin-top:6px;border-top:1px solid rgba(29,158,117,.3)"><span>Total</span><span style="color:#5DCAA5">₹'+grand+'</span></div>';
}

function customerDoneEating(){
  var items=Object.values(custCart);
  var t=ld('bb_tax',{cgst:2.5,sgst:2.5});
  var sub=items.reduce(function(s,i){return s+i.qty*i.price;},0);
  var cr=parseFloat(t.cgst)||2.5;
  var sr=parseFloat(t.sgst)||2.5;
  var cgst=(sub*cr/100).toFixed(2);
  var sgst=(sub*sr/100).toFixed(2);
  var grand=(sub+parseFloat(cgst)+parseFloat(sgst)).toFixed(2);

  // Show "waiter is coming" screen
  showCustScreen('screenWaitingPayment');
  document.getElementById('waitingPayTotal').textContent='₹'+grand;

  // Notify waiter via Firebase
  loadPendingOrders().then(function(pending){
    var idx=pending.findIndex(function(o){return o.id===custCurrentOrderId;});
    if(idx>-1){
      pending[idx].status='payment_requested';
      pending[idx].grandTotal=grand;
      pending[idx].paymentRequestTime=new Date().toLocaleString('en-IN');
      savePendingOrders(pending);
    }
  });
  logActivity('bill','Payment Requested','Table '+custTableNo+' done eating. Bill: ₹'+grand,'💰');

  // Poll for payment confirmation from waiter
  if(custPollInterval)clearInterval(custPollInterval);
  custPollInterval=setInterval(async function(){
    var all=await loadPendingOrders();
    var order=all.find(function(o){return o.id===custCurrentOrderId;});
    if(order&&order.status==='payment_done'){
      clearInterval(custPollInterval);
      showCustScreen('paymentDone');
      document.getElementById('paymentDoneMsg').innerHTML=
        'Payment of <strong style="color:#5DCAA5">₹'+order.grandTotal+'</strong>'
        +(order.paymentMethod?' via <strong style="color:#fff">'+order.paymentMethod+'</strong>':'')
        +' received!<br>Thank you for dining with us! 🙏';
    }
  },3000);
}

function showCustScreen(screenId){
  ['screenWaiting','screenAccepted','screenWaitingPayment','paymentDone'].forEach(function(id){
    var el=document.getElementById(id);
    if(el)el.classList.remove('show');
  });
  var target=document.getElementById(screenId);
  if(target)target.classList.add('show');
}


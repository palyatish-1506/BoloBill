async function generateCustPayQR(amount){
  var p=ld('bb_profile',DEFAULT_PROFILE);
  var upiId=p.upiId||'';
  var wrap=document.getElementById('custQrWrap');

  // Fetch from Firebase if not in local profile
  if(!upiId){
    var fbUrl=getFirebaseUrl();
    if(fbUrl){
      try{
        var res=await fetch(fbUrl+'/profile.json?t='+Date.now());
        var fp=await res.json();
        if(fp&&fp.upiId){upiId=fp.upiId;}
      }catch(e){}
    }
  }

  // Store globally for Pay Now button and copy function
  window._custUpiId=upiId;
  window._custUpiAmt=amount;

  // Fill manual UPI display
  var manualEl=document.getElementById('manualUpiId');
  var manualAmtEl=document.getElementById('manualUpiAmt');
  if(manualEl)manualEl.textContent=upiId||'Not configured';
  if(manualAmtEl)manualAmtEl.textContent='₹'+amount;

  if(!upiId){
    if(wrap)wrap.innerHTML='<div style="width:180px;height:100px;background:#f0f0f0;display:flex;align-items:center;justify-content:center;border-radius:8px;margin:0 auto;text-align:center;padding:12px;font-size:12px;color:#999">UPI ID not set.<br>Use Cash.</div>';
    return;
  }

  var upiUrl='upi://pay?pa='+encodeURIComponent(upiId)
    +'&pn='+encodeURIComponent(p.name||'Restaurant')
    +'&am='+amount
    +'&cu=INR'
    +'&tn='+encodeURIComponent('BoloBill Table '+custTableNo);

  if(wrap){
    wrap.innerHTML='<div id="custQrDiv" style="display:flex;justify-content:center;margin-bottom:6px"></div>'
      +'<div style="font-size:11px;color:#555;text-align:center">Scan from another device · Pay to: '+upiId+'</div>';

    if(typeof QRCode!=='undefined'){
      try{
        new QRCode(document.getElementById('custQrDiv'),{
          text:upiUrl,width:180,height:180,
          colorDark:'#000000',colorLight:'#ffffff',
          correctLevel:QRCode.CorrectLevel.M
        });
      }catch(e){showQRFallback(upiId,amount);}
    } else {
      wrap.innerHTML='<img src="https://chart.googleapis.com/chart?chs=180x180&cht=qr&chl='+encodeURIComponent(upiUrl)+'" '
        +'width="180" height="180" style="border-radius:8px;display:block;margin:0 auto">'
        +'<div style="font-size:11px;color:#555;margin-top:6px;text-align:center">Scan from another device</div>';
    }
  }
}


    +'.order-elapsed{font-size:11px;font-weight:700;padding:2px 8px;border-radius:20px;background:rgba(29,158,117,.2);color:#5DCAA5}'
    +'.order-elapsed.warn{background:rgba(217,79,79,.2);color:#f87171}'
    +'.order-items{padding:10px 14px}'
    +'.order-item{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.04)}'
    +'.order-item:last-child{border-bottom:none}'
    +'.item-qty{width:28px;height:28px;border-radius:50%;background:rgba(29,158,117,.25);color:#5DCAA5;font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0}'
    +'.item-name{font-size:13px;font-weight:600;color:#fff}'
    +'.item-cat{font-size:10px;color:rgba(255,255,255,.35);margin-top:1px}'
    +'.order-foot{padding:10px 14px;display:flex;gap:6px;border-top:1px solid rgba(255,255,255,.06)}'
    +'.kds-btn{flex:1;padding:8px;border-radius:8px;border:none;cursor:pointer;font-size:12px;font-weight:700;font-family:inherit;transition:all .15s}'
    +'.kds-btn-done{background:#1D9E75;color:#fff}'
    +'.kds-btn-skip{background:rgba(255,255,255,.06);color:rgba(255,255,255,.5);border:1px solid rgba(255,255,255,.1)}'
    +'.empty{text-align:center;padding:4rem;color:rgba(255,255,255,.25);font-size:15px}'
    +'.new-badge{background:#1D9E75;color:#fff;font-size:9px;font-weight:800;padding:2px 6px;border-radius:10px;letter-spacing:.5px}';

  var html='<!DOCTYPE html><html><head>'
    +'<meta charset="UTF-8"/>'
    +'<title>BoloBill - Kitchen Display</title>'
    +'<style>'+css+'</style>'
    +'</head><body>'
    +'<div class="kds-header">'
      +'<div><div class="kds-title">Kitchen Display</div><div class="kds-subtitle">BoloBill - Live Order Feed</div></div>'
      +'<div class="kds-clock" id="kdsClock"></div>'
    +'</div>'
    +'<div class="kds-stats">'
      +'<div class="kds-stat">Pending: <span id="statPending">0</span></div>'
      +'<div class="kds-stat">Done today: <span id="statDone">0</span></div>'
      +'<div class="kds-stat">Avg time: <span id="statAvg">-</span></div>'
    +'</div>'
    +'<div class="orders-grid" id="ordersGrid"></div>';

  // Build the KDS script as a string safely
  var kdsScript=''
    +'var doneCount=0,doneArr=[];'
    +'function getOrders(){try{return JSON.parse(localStorage.getItem("bb_kds_orders")||"[]");}catch(e){return[];}}'
    +'function saveOrders(o){localStorage.setItem("bb_kds_orders",JSON.stringify(o));}'
    +'function elapsed(ts){var d=Math.floor((Date.now()-ts)/1000);if(d<60)return d+"s";return Math.floor(d/60)+"m "+d%60+"s";}'
    +'function isUrgent(ts){return(Date.now()-ts)>8*60*1000;}'
    +'function render(){'
      +'var orders=getOrders().filter(function(o){return!o.done;});'
      +'var grid=document.getElementById("ordersGrid");'
      +'document.getElementById("statPending").textContent=orders.length;'
      +'document.getElementById("statDone").textContent=doneCount;'
      +'document.getElementById("statAvg").textContent=doneArr.length?(Math.round(doneArr.reduce(function(a,b){return a+b;},0)/doneArr.length/1000)+"s"):"-";'
      +'if(!orders.length){grid.innerHTML="<div class=\'empty\'>All orders ready! Kitchen is clear.</div>";return;}'
      +'var html="";'
      +'orders.forEach(function(o,i){'
        +'var itemsHtml="";'
        +'(o.items||[]).forEach(function(it){'
          +'itemsHtml+="<div class=\'order-item\'><div class=\'item-qty\'>"+it.qty+"</div><div><div class=\'item-name\'>"+it.name+"</div><div class=\'item-cat\'>"+(it.cat||"")+"</div></div></div>";'
        +'});'
        +'var urgent=isUrgent(o.ts)?" urgent":"";'
        +'var warn=isUrgent(o.ts)?" warn":"";'
        +'html+="<div class=\'order-card"+urgent+"\' id=\'card-"+i+"\'>"'
          +'+"<div class=\'order-head\'>"'
            +'+"<div><div class=\'order-table\'>Table "+o.table+"</div><div class=\'order-waiter\'>Waiter: "+o.waiter+"</div></div>"'
            +'+"<div style=\'text-align:right\'><div class=\'order-elapsed"+warn+"\' id=\'el-"+i+"\'>"+elapsed(o.ts)+"</div><div class=\'order-time\'>"+new Date(o.ts).toLocaleTimeString("en-IN",{hour:"2-digit",minute:"2-digit"})+"</div></div>"'
          +'+"</div>"'
          +'+"<div class=\'order-items\'>"+itemsHtml+"</div>"'
          +'+"<div class=\'order-foot\'>"'
            +'+"<button class=\'kds-btn kds-btn-done\' onclick=\'markDone("+i+")\'>Done - Ready</button>"'
            +'+"<button class=\'kds-btn kds-btn-skip\' onclick=\'markDelay("+i+")\'>Delay</button>"'
          +'+"</div></div>";'
      +'});'
      +'grid.innerHTML=html;'
    +'}'
    +'function markDone(i){'
      +'var orders=getOrders().filter(function(o){return!o.done;});'
      +'if(!orders[i])return;'
      +'var timeTaken=Date.now()-orders[i].ts;'
      +'doneArr.push(timeTaken);doneCount++;'
      +'var allOrders=getOrders();'
      +'var idx=allOrders.findIndex(function(o){return o.id===orders[i].id;});'
      +'if(idx>-1){allOrders[idx].done=true;saveOrders(allOrders);}'
      +'render();'
    +'}'
    +'function markDelay(i){'
      +'var orders=getOrders().filter(function(o){return!o.done;});'
      +'if(!orders[i])return;'
      +'alert("Order for Table "+orders[i].table+" marked as delayed.");'
    +'}'
    +'function tick(){'
      +'document.getElementById("kdsClock").textContent=new Date().toLocaleTimeString("en-IN",{hour:"2-digit",minute:"2-digit",second:"2-digit"});'
      +'render();'
    +'}'
    +'tick();setInterval(tick,1000);'
    +'window.addEventListener("storage",function(e){if(e.key==="bb_kds_orders")render();});';

  html+='</body></html>';
  kdsWin.document.open();
  kdsWin.document.write(html);
  kdsWin.document.close();
  // Inject script safely after document is written
  var s=kdsWin.document.createElement('script');
  s.textContent=kdsScript;
  kdsWin.document.body.appendChild(s);
}

function sendToKitchen(orderData){
  const orders=JSON.parse(localStorage.getItem('bb_kds_orders')||'[]');
  orders.unshift({
    id:Date.now().toString(),
    table:orderData.table,
    waiter:orderData.waiter,
    items:orderData.items,
    ts:Date.now(),
    done:false,
    isNew:true
  });
  if(orders.length>50)orders.pop();
  localStorage.setItem('bb_kds_orders',JSON.stringify(orders));
  logActivity('bill','Sent to Kitchen','Table '+orderData.table+' order sent to KDS','👨‍🍳');
}
</script>

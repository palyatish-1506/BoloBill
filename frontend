function toggleCustMic(){
  if(!('webkitSpeechRecognition' in window||'SpeechRecognition' in window)){
    document.getElementById('custVoiceText').textContent='Voice not supported. Use Chrome browser.';return;
  }
  if(custMicRec){custRecognition&&custRecognition.stop();return;}
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  custRecognition=new SR();
  custRecognition.lang=ld('bb_lang','en-IN');
  custRecognition.continuous=false;custRecognition.interimResults=true;
  custRecognition.onstart=()=>{
    custMicRec=true;
    document.getElementById('custMicBtn').classList.add('rec');
    document.getElementById('custVoiceText').textContent='🔴 Listening... speak your order';
    document.getElementById('custVoiceText').classList.add('active');
  };
  custRecognition.onresult=(e)=>{
    let t='';for(let i=0;i<e.results.length;i++)t+=e.results[i][0].transcript;
    document.getElementById('custVoiceText').textContent=t;
  };
  custRecognition.onend=()=>{
    custMicRec=false;
    document.getElementById('custMicBtn').classList.remove('rec');
    document.getElementById('custVoiceText').classList.remove('active');
    const text=document.getElementById('custVoiceText').textContent;
    if(!text||text==='🔴 Listening... speak your order')return;
    processCustVoice(text);
  };
  custRecognition.onerror=()=>{
    custMicRec=false;
    document.getElementById('custMicBtn').classList.remove('rec');
    document.getElementById('custVoiceText').textContent='Mic error. Please try again.';
    document.getElementById('custVoiceText').classList.remove('active');
  };
  custRecognition.start();
}

async function processCustVoice(text){
  document.getElementById('custVoiceText').textContent='Parsing order...';
  const key=ld('bb_apikey','');
  let items=[];
  if(key){
    try{
      items=await parseWithGemini(text,key);
    }catch(e){
      items=parseLocal(text);
    }
  } else {
    items=parseLocal(text);
  }
  if(items&&items.length){
    items.forEach(function(i){
      if(custCart[i.name])custCart[i.name].qty+=i.qty;
      else custCart[i.name]={name:i.name,price:i.price,qty:i.qty};
    });
    updateCartBadge();
    renderCustMenu(custFilterCat);
    document.getElementById('custVoiceText').textContent='✅ Added: '+items.map(function(i){return i.qty+'x '+i.name;}).join(', ');
  } else {
    document.getElementById('custVoiceText').textContent='Could not recognise items. Please try again or tap + to add.';
  }
}


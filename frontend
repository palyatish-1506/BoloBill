  document.getElementById('changeAmt').textContent='₹0.00';
  // Load saved UPI ID — prefer profile UPI over saved UPI
  const p=ld('bb_profile',DEFAULT_PROFILE);
  const savedUpi=p.upiId||ld('bb_upi','')||'';
  document.getElementById('upiId').value=savedUpi;

function verifyPin(){
  const p=ld('bb_profile',DEFAULT_PROFILE);

  if(loginRole==='manager'){
    if(pinBuffer===(p.mgrPin||'1234')){
      loginSuccess('manager','Manager','Full Access');
    } else {
      pinFail();
    }
  } else if(loginRole==='waiter' && loginWaiter){
    if(pinBuffer===loginWaiter.pin){
      loginSuccess('waiter',loginWaiter.name,loginWaiter.id);
    } else {
      pinFail();
    }
  }
}

function pinFail(){
  failedAttempts++;
  for(let i=0;i<4;i++)document.getElementById('pd'+i).classList.add('error');
  logActivity('warning','Failed Login','Incorrect PIN attempt for '+(loginWaiter?loginWaiter.name:'Manager')+' (Attempt '+failedAttempts+')','🚫');

  if(failedAttempts>=3){
    lockedUntil=Date.now()+30000;
    document.getElementById('lockoutMsg').style.display='block';
    document.getElementById('pinError').textContent='';
    let secs=30;
    const t=setInterval(()=>{
      secs--;document.getElementById('lockoutTimer').textContent=secs;
      if(secs<=0){clearInterval(t);lockedUntil=0;failedAttempts=0;document.getElementById('lockoutMsg').style.display='none';pinBuffer='';updatePinDisplay();}
    },1000);
    logActivity('danger','Account Locked','Too many failed PIN attempts — locked for 30 seconds','🔒');
  } else {
    const left=3-failedAttempts;
    document.getElementById('pinError').textContent='Incorrect PIN. '+left+' attempt'+(left===1?'':'s')+' remaining.';
    setTimeout(()=>{pinBuffer='';updatePinDisplay();},600);
  }
}


function closePayModal(){document.getElementById('payModal').style.display='none';}
function switchPM(mode){
  ['cash','upi','card'].forEach(m=>{
    document.getElementById('pm-'+m).style.display=m===mode?'block':'none';
    document.getElementById('tab-'+m).classList.toggle('active',m===mode);
  });
  if(mode==='upi')setTimeout(generateQR,50);
}
function calcChange(){
  const total=parseFloat(document.getElementById('grandTotal').textContent.replace('₹','').replace(',',''))||0;
  const received=parseFloat(document.getElementById('cashReceived').value)||0;
  const change=received-total;
  const el=document.getElementById('changeAmt');
  if(received===0){el.textContent='₹0.00';el.style.color='#5DCAA5';return;}
  if(change<0){el.textContent='₹'+Math.abs(change).toFixed(2)+' short';el.style.color='#D94F4F';}
  else{el.textContent='₹'+change.toFixed(2);el.style.color='#5DCAA5';}
}
function generateQR(){
  var p=ld('bb_profile',DEFAULT_PROFILE);
  var upiId=document.getElementById('upiId').value.trim()||p.upiId||'';
  if(!upiId){document.getElementById('upiIdDisplay').textContent='Enter UPI ID above';return;}
  var amount=document.getElementById('pmAmount').textContent.replace('₹','').replace(/,/g,'').trim();
  var upiUrl='upi://pay?pa='+encodeURIComponent(upiId)+'&pn='+encodeURIComponent(p.name)+'&am='+amount+'&cu=INR&tn='+encodeURIComponent('BoloBill Payment');
  document.getElementById('upiIdDisplay').textContent='Pay to: '+upiId;
  sv('bb_upi',upiId);
  // Clear and regenerate QR
  var wrap=document.getElementById('qrCanvasWrap');
  if(!wrap){
    // fallback — use canvas id directly
    var canvas=document.getElementById('qrCanvas');
    if(typeof QRCode!=='undefined'){
      canvas.parentElement.innerHTML='<div id="qrCanvasWrap"></div>';
      new QRCode(document.getElementById('qrCanvasWrap'),{text:upiUrl,width:200,height:200,colorDark:'#000',colorLight:'#fff',correctLevel:QRCode.CorrectLevel.M});
    }
    return;
  }
  wrap.innerHTML='';
  if(typeof QRCode!=='undefined'){
    try{
      new QRCode(wrap,{text:upiUrl,width:200,height:200,colorDark:'#000000',colorLight:'#ffffff',correctLevel:QRCode.CorrectLevel.M});
    }catch(e){
      wrap.innerHTML='<img src="https://chart.googleapis.com/chart?chs=200x200&cht=qr&chl='+encodeURIComponent(upiUrl)+'" width="200" height="200" style="border-radius:8px">';
    }
  } else {
    wrap.innerHTML='<img src="https://chart.googleapis.com/chart?chs=200x200&cht=qr&chl='+encodeURIComponent(upiUrl)+'" width="200" height="200" style="border-radius:8px">';
  }
}

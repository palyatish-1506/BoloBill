async function processOrder(){
  if(isRec){recognition&&recognition.stop();stopMicUI();}
  const text=document.getElementById('transcript').value.trim();
  if(!text){setW('Please speak or type an order first.','err');return;}

  const key=ld('bb_apikey','');
  let aiTried=false;

  if(key){
    aiTried=true;
    setW('🤖 Gemini AI parsing...','info');
    try{
      const items=await parseWithGemini(text,key);
      if(items&&items.length){
        orderItems=items;renderBill();
        setW('✅ AI parsed '+items.length+' item(s) — bill ready!','ok');
        logActivity('bill','AI Order Parsed','Gemini: '+items.map(i=>i.qty+'x '+i.name).join(', '),'🤖');
        return;
      }
      setW('AI returned no items — using smart local parser...','info');
    } catch(e){
      const msg=e.message||'';
      if(msg.includes('quota')||msg.includes('429')||msg.includes('RESOURCE_EXHAUSTED')){
        setW('⚠️ AI quota exceeded — using smart local parser (works great!)','info');
      } else {
        setW('AI unavailable — using smart local parser...','info');
      }
      logActivity('warning','AI Fallback',msg.substring(0,80),'⚠️');
    }
  }

  // Smart local parser — always runs as fallback
  setTimeout(()=>{
    const items=parseLocal(text);
    if(!items||!items.length){
      setW('No items found. Try: "2 paneer butter masala, 1 naan"','err');
      return;
    }
    orderItems=items;renderBill();
    setW((aiTried?'🔄 Local: ':'✅ ')+items.length+' item(s) found!','ok');
    logActivity('bill','Order Parsed','Local parser: '+items.map(i=>i.qty+'x '+i.name).join(', '),'🧾');
  }, aiTried?800:0);
}

async function parseWithGemini(text,key){
  const activeMenu=menu.filter(m=>m.active).map(m=>m.name).join(', ');
  const prompt=`You are a restaurant order parser for an Indian restaurant.
Available menu items: ${activeMenu}

Customer order: "${text}"

Rules:
- Match even if spoken differently: "butter paneer"→"Paneer Butter Masala", "paneer masala"→"Paneer Butter Masala"
- Handle Hindi/Gujarati numbers: ek=1,do=2,teen=3,char=4,paanch=5,be=2,tran=3,panch=5
- Handle abbreviated names: "dal"→"Dal Tadka", "biryani"→"Veg Biryani", "lassi"→"Mango Lassi"
- Return ONLY a JSON array. No markdown. No text before or after.
- Format: [{"name":"exact item name from list","qty":1}]
- Unknown items: skip them
- Nothing matches: return []`;

  const res=await fetch('https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent',{
    method:'POST',
    headers:{'Content-Type':'application/json','x-goog-api-key':key},
    body:JSON.stringify({
      contents:[{parts:[{text:prompt}]}],
      generationConfig:{temperature:0.1,maxOutputTokens:400}
    })
  });

  if(res.status===429){throw new Error('quota exceeded — rate limit hit');}
  if(!res.ok){throw new Error('HTTP '+res.status);}

  const data=await res.json();
  if(data.error){
    const msg=data.error.message||'Unknown error';
    throw new Error(msg);
  }

  const raw=data.candidates?.[0]?.content?.parts?.[0]?.text||'[]';
  const clean=raw.replace(/```json|```/gi,'').trim();
  let parsed=[];
  try{parsed=JSON.parse(clean);}
  catch(_){
    const match=clean.match(/\[[\s\S]*?\]/);
    try{parsed=match?JSON.parse(match[0]):[];}catch(_){parsed=[];}
  }

  return parsed.map(p=>{
    const pname=(p.name||'').toLowerCase().trim();
    // 1. exact match
    let found=menu.find(m=>m.active&&m.name.toLowerCase()===pname);
    // 2. contains match
    if(!found)found=menu.find(m=>m.active&&m.name.toLowerCase().includes(pname));
    // 3. reverse: menu item name contains what AI said
    if(!found)found=menu.find(m=>m.active&&pname.includes(m.name.toLowerCase()));
    // 4. first-word match
    if(!found){const fw=pname.split(' ')[0];if(fw.length>2)found=menu.find(m=>m.active&&m.name.toLowerCase().includes(fw));}
    if(!found)return null;
    return{name:found.name,qty:Math.max(1,parseInt(p.qty)||1),price:found.price,hsn:found.hsn,cat:found.cat};
  }).filter(Boolean);
}

function parseLocal(text){
  const lower=text.toLowerCase().replace(/[,\.!?]/g,' ');
  const nw={one:1,two:2,three:3,four:4,five:5,six:6,seven:7,eight:8,nine:9,ten:10,
            ek:1,do:2,teen:3,char:4,paanch:5,be:2,tran:3,panch:5};
  const found={};
  const active=menu.filter(m=>m.active).sort((a,b)=>b.name.length-a.name.length);

  // Pass 1: exact substring match
  let rem=lower;
  for(const item of active){
    const key=item.name.toLowerCase();
    const idx=rem.indexOf(key);
    if(idx===-1)continue;
    const before=rem.slice(0,idx);
    const nm=before.match(/(\d+|one|two|three|four|five|six|seven|eight|nine|ten|ek|do|teen|char|paanch|be|tran|panch)\s*$/i);
    let qty=1;
    if(nm){qty=isNaN(nm[1])?(nw[nm[1].toLowerCase()]||1):parseInt(nm[1]);rem=rem.slice(0,idx-nm[0].length)+rem.slice(idx+key.length);}
    else{rem=rem.slice(0,idx)+rem.slice(idx+key.length);}
    found[item.name]=(found[item.name]||0)+qty;
  }

  // Pass 2: fuzzy — check if ALL words of item name appear in text
  for(const item of active){
    if(found[item.name])continue;
    const words=item.name.toLowerCase().split(' ').filter(w=>w.length>2);
    const matchCount=words.filter(w=>lower.includes(w)).length;
    if(words.length>0&&matchCount>=Math.ceil(words.length*0.6)){
      // extract qty from nearby context
      const firstWord=words[0];
      const idx=lower.indexOf(firstWord);
      let qty=1;
      if(idx>0){
        const before=lower.slice(Math.max(0,idx-8),idx);
        const nm=before.match(/(\d+|one|two|three|four|five|six|seven|eight|nine|ten|ek|do|teen|char|paanch)\s*$/i);
        if(nm)qty=isNaN(nm[1])?(nw[nm[1].toLowerCase()]||1):parseInt(nm[1]);
      }
      found[item.name]=(found[item.name]||0)+qty;
    }
  }

  return Object.entries(found).map(([n,q])=>{
    const m2=menu.find(x=>x.name===n);
    return m2?{name:n,qty:q,price:m2.price,hsn:m2.hsn,cat:m2.cat}:null;
  }).filter(Boolean);
}


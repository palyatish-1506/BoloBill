        +'<button class="btn btn-r btn-sm" style="flex-shrink:0" onclick="rejectOrder(\''+o.id+'\')">✕</button>';
    } else {
      html+='<button class="btn btn-g btn-sm" style="flex:1;justify-content:center" onclick="acceptOrder(\''+o.id+'\')">✅ Accept & Add to Bill</button>'
        +(o.customerPhone?'<button class="btn btn-sm" style="background:rgba(37,211,102,.15);border-color:rgba(37,211,102,.4);color:#25D166;flex-shrink:0" onclick="sendBillToCustomerWA(\''+o.id+'\')">💬</button>':'')
        +'<button class="btn btn-r btn-sm" style="flex-shrink:0" onclick="rejectOrder(\''+o.id+'\')">✕</button>';

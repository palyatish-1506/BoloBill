function landingLogin(){
  var name=(document.getElementById('landingName').value||'').trim();
  var phone=(document.getElementById('landingPhone').value||'').trim();
  var errEl=document.getElementById('landingError');

  if(!name){errEl.textContent='Please enter your name.';document.getElementById('landingName').focus();return;}
  if(!phone||phone.length<10){errEl.textContent='Please enter a valid 10-digit WhatsApp number.';document.getElementById('landingPhone').focus();return;}
  errEl.textContent='';

  // Remove landing page
  var landing=document.getElementById('custLanding');
  if(landing)landing.remove();

  // Pre-fill and call customerLogin
  var tableEl=document.getElementById('customerTable');
  var nameEl=document.getElementById('customerName');
  var phoneEl=document.getElementById('customerPhone');
  if(tableEl)tableEl.value=window._landingTable||'T-01';
  if(nameEl)nameEl.value=name;
  if(phoneEl)phoneEl.value=phone;

  customerLogin();
}

function customerLogin(){
  const table=(document.getElementById('customerTable').value||'').trim().toUpperCase()||window._landingTable||'T-01';
  const name=(document.getElementById('customerName').value||'').trim();
  const phone=(document.getElementById('customerPhone').value||'').trim();
  const el=document.getElementById('customerEntryStatus');

  if(!table){if(el){el.textContent='Please enter your table number.';el.className='status err';}return;}
  if(!name){if(el){el.textContent='Please enter your name.';el.className='status err';}if(document.getElementById('customerName'))document.getElementById('customerName').focus();return;}
  if(!phone||phone.length<10){if(el){el.textContent='Please enter a valid 10-digit WhatsApp number.';el.className='status err';}if(document.getElementById('customerPhone'))document.getElementById('customerPhone').focus();return;}

  custTableNo=table;
  custPhone=phone;
  custCustomerName=name;
  custCart={};

  if(document.getElementById('loginScreen'))document.getElementById('loginScreen').style.display='none';
  document.getElementById('customerApp').style.display='block';

  const p=ld('bb_profile',DEFAULT_PROFILE);
  document.getElementById('custRestName').textContent=p.name;
  document.getElementById('custTableDisplay').textContent='Table '+table+' · '+name;

  // Show welcome banner briefly
  var banner=document.getElementById('custWelcomeBanner');
  if(banner){
    document.getElementById('welcomeRestName').textContent=p.name;
    document.getElementById('welcomeRestAddr').textContent=(p.addr?p.addr+' · ':'')+p.city;
    document.getElementById('welcomeTableNo').textContent=table;
    banner.style.display='block';
    setTimeout(function(){
      banner.style.transition='opacity .6s ease';
      banner.style.opacity='0';
      setTimeout(function(){banner.style.display='none';banner.style.opacity='1';banner.style.transition='';},600);
    },3500);
  }

  logActivity('info','Customer Login','Customer '+name+' ('+phone+') at table '+table+' opened self-order menu','🪑');
  renderCustMenu('All');
}

const FOOD_EMOJIS={
  'Main Course':'🍛','Rice':'🍚','Bread':'🍞','Beverages':'🥤',
  'Starters':'🥗','Sides':'🥣','Desserts':'🍮','Default':'🍽️'
};

const VEG_ITEMS=['Paneer Butter Masala','Dal Tadka','Dal Makhani','Shahi Paneer',
  'Mix Veg','Veg Biryani','Garlic Naan','Butter Naan','Naan','Roti','Paratha',
  'Jeera Rice','Steamed Rice','Mango Lassi','Masala Chai','Cold Coffee',
  'Fresh Lime Soda','Mineral Water','Raita','Papad','Salad','Gulab Jamun',
  'Kheer','Ice Cream','Samosa','Veg Soup'];

function renderCustMenu(cat){
  custFilterCat=cat;
  const m=ld('bb_menu',DEFAULT_MENU).filter(function(i){return i.active;});
  const catSet=['All'];
  m.forEach(function(i){if(catSet.indexOf(i.cat)===-1)catSet.push(i.cat);});
  // Render category tabs
  var tabsHtml='';
  catSet.forEach(function(c){
    var isActive=c===cat?'active':'';
    tabsHtml+='<button class="cust-cat '+isActive+'" onclick="renderCustMenu(\''+c+'\')">'+c+'</button>';
  });
  document.getElementById('custCats').innerHTML=tabsHtml;
  // Count top items
  const h=ld('bb_history',[]);
  const ic={};
  h.forEach(function(b){(b.items||[]).forEach(function(i){ic[i.name]=(ic[i.name]||0)+i.qty;});});
  const top3=Object.entries(ic).sort(function(a,b){return b[1]-a[1];}).slice(0,3).map(function(x){return x[0];});
  const filtered=cat==='All'?m:m.filter(function(i){return i.cat===cat;});
  var gridHtml='';
  filtered.forEach(function(item){
    const emoji=FOOD_EMOJIS[item.cat]||FOOD_EMOJIS['Default'];
    const isTop=top3.indexOf(item.name)!==-1;
    const isVeg=VEG_ITEMS.indexOf(item.name)!==-1;
    const cartQty=(custCart[item.name]&&custCart[item.name].qty)||0;
    const safeId=item.name.replace(/\s+/g,'_').replace(/[^a-zA-Z0-9_]/g,'');
    const inCart=cartQty>0?'in-cart':'';
    var qtyCtrl='';
    if(cartQty===0){
      qtyCtrl='<button class="cust-add-btn" onclick="custAddItem(\''+item.name+'\','+item.price+')">+</button>';
    } else {
      qtyCtrl='<div class="cust-qty-ctrl">'
        +'<button class="cust-qty-btn" onclick="custChangeQty(\''+item.name+'\',-1)">−</button>'
        +'<span class="cust-qty-val">'+cartQty+'</span>'
        +'<button class="cust-qty-btn" onclick="custChangeQty(\''+item.name+'\',1)">+</button>'
        +'</div>';
    }
    gridHtml+='<div class="cust-card '+inCart+'" id="ccard-'+safeId+'">'
      +'<div class="cust-card-img">'+emoji+'</div>'
      +(isTop?'<div class="top-badge">⭐ Top Pick</div>':'')
      +(isVeg?'<div class="veg-dot"></div>':'')
      +'<div class="cust-card-body">'
        +'<div class="cust-card-name">'+item.name+'</div>'
        +'<div class="cust-card-cat">'+item.cat+'</div>'
        +'<div class="cust-card-footer">'
          +'<div class="cust-price">₹'+item.price+'</div>'
          +qtyCtrl
        +'</div>'
      +'</div>'
    +'</div>';
  });
  document.getElementById('custGrid').innerHTML=gridHtml;
}

function custAddItem(name,price){
  custCart[name]={name,price,qty:1};
  updateCartBadge();renderCustMenu(custFilterCat);
}
function custChangeQty(name,d){
  if(!custCart[name])return;
  custCart[name].qty+=d;
  if(custCart[name].qty<=0)delete custCart[name];
  updateCartBadge();renderCustMenu(custFilterCat);
}

async function acceptOrder(id){
  const all=await loadPendingOrders();
  const order=all.find(o=>o.id===id);
  if(!order)return;

  // Mark accepted so customer phone sees it, then remove from waiter list
  order.status='accepted';
  savePendingOrders(all);

  // Load into bill
  document.getElementById('tableNo').value=order.table;
  order.items.forEach(i=>{
    const existing=orderItems.find(x=>x.name===i.name);
    if(existing)existing.qty+=i.qty;
    else{const m2=menu.find(x=>x.name===i.name);if(m2)orderItems.push({name:i.name,qty:i.qty,price:m2.price,hsn:m2.hsn,cat:m2.cat});}
  });
  renderBill();
  switchTab('waiter',document.getElementById('nav-waiter'));
  logActivity('bill','Order Accepted','Customer order from Table '+order.table+' accepted','✅');
  setW('✅ Customer order from Table '+order.table+' loaded into bill!','ok');

  // Remove from pending list — no longer needs to show
  const cleaned=all.filter(o=>o.id!==id);
  // But keep in Firebase with 'accepted' status so customer phone still polls correctly
  // Just refresh the UI to remove it from waiter view
  renderPendingOrders();
}

async function rejectOrder(id){
  if(!confirm('Reject this order?'))return;
  const all=await loadPendingOrders();
  // Remove completely from Firebase
  const cleaned=all.filter(o=>o.id!==id);
  savePendingOrders(cleaned);
  renderPendingOrders();
}

// Waiter collects payment — opens payment modal with correct amount
async function collectPayment(orderId){
  const all=await loadPendingOrders();
  const order=all.find(o=>o.id===orderId);
  if(!order)return;

  const grand=order.grandTotal||'0';

  // ── IMMEDIATELY remove from list + local storage ──
  // Keep a copy for payment_done notification to customer
  const cleaned=all.filter(o=>o.id!==orderId);
  sv('bb_pending_orders', cleaned); // remove from local immediately

  // Remove from Firebase right now (don't wait)
  // We'll write payment_done separately for customer phone
  savePendingOrders(cleaned);

  // Store order data for confirmPayment to use
  window._currentPayOrderId=orderId;
  window._currentPayOrderData=order;

  // Refresh UI — it's gone now
  renderPendingOrders();

  // Load items into bill
  if(order.items&&order.items.length){
    orderItems=[];
    order.items.forEach(function(i){
      const m2=menu.find(x=>x.name===i.name);
      if(m2)orderItems.push({name:i.name,qty:i.qty,price:m2.price,hsn:m2.hsn,cat:m2.cat});
    });
    document.getElementById('tableNo').value=order.table;
    renderBill();
  }

  // Switch to waiter tab and open payment modal
  switchTab('waiter',document.getElementById('nav-waiter'));
  setTimeout(function(){
    const grandTotalEl=document.getElementById('grandTotal');
    if(grandTotalEl)grandTotalEl.textContent='₹'+grand;
    openPayModal();
  },300);

  setW('💰 Table '+order.table+' — ₹'+grand+'. Collect payment below.','ok');
  logActivity('bill','Collect Payment','Going to collect ₹'+grand+' from Table '+order.table,'💰');
}

// Called when waiter confirms payment
const _originalConfirmPayment=typeof confirmPayment==='function'?confirmPayment:null;
async function confirmPayment(method){
  if(method==='Cash'){
    const total=parseFloat(document.getElementById('grandTotal').textContent.replace('₹','').replace(',',''))||0;
    const received=parseFloat(document.getElementById('cashReceived').value)||0;
    if(received<total){alert('Amount received is less than total! Please enter correct amount.');return;}
  }
  closePayModal();
  finalizeBill(method);

  // Notify customer phone that payment is done
  if(window._currentPayOrderId){
    const payId=window._currentPayOrderId;
    const orderData=window._currentPayOrderData;
    window._currentPayOrderId=null;
    window._currentPayOrderData=null;

    // Write a tiny payment_done record to Firebase so customer phone sees "Thank You"
    // Use a separate key so it doesn't pollute the orders list
    const fbUrl=getFirebaseUrl();
    if(fbUrl&&orderData){
      try{
        // Temporarily add payment_done entry, delete after 15s
        const payDoneEntry={
          id:payId,
          status:'payment_done',
          paymentMethod:method,
          grandTotal:orderData.grandTotal||'0',
          table:orderData.table||''
        };
        const all=await loadPendingOrders();
        // Only add if not already there
        if(!all.find(o=>o.id===payId)){
          all.push(payDoneEntry);
          await savePendingOrders(all);
          // Delete after 15 seconds — customer phone has seen it by then
          setTimeout(async function(){
            const latest=await loadPendingOrders();
            const c=latest.filter(o=>o.id!==payId);
            savePendingOrders(c);
          },15000);
        }
      }catch(e){}
    }
    logActivity('bill','Payment Done','Payment collected via '+method,'✅');
  }
}


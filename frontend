const SYNC_KEY='bb_firebase_url';

function getFirebaseUrl(){
  // Hardcoded Firebase URL — works on ALL devices automatically
  var HARDCODED = 'https://bolobill-7ca13-default-rtdb.firebaseio.com';
  // Use saved URL if different one configured, else use hardcoded
  var saved = ld(SYNC_KEY,'');
  var url = saved || HARDCODED;
  url = url.replace(/\/+$/, '');
  if(url.includes('/orders') || url.includes('/test')){
    url = url.split('/orders')[0].split('/test')[0];
  }
  return url;
}

// Save orders to Firebase
async function savePendingOrders(orders){
  sv('bb_pending_orders', orders);
  var fbUrl = getFirebaseUrl();
  if(!fbUrl){ console.log('BoloBill: No Firebase URL set'); return; }
  try{
    var res = await fetch(fbUrl + '/orders.json', {
      method: 'PUT',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify(orders)
    });
    if(!res.ok) console.log('BoloBill: Firebase save failed:', res.status, res.statusText);
    else console.log('BoloBill: Orders saved to Firebase ✅', orders.length, 'orders');
  }catch(e){ console.log('BoloBill: Firebase save error:', e.message); }
}

// Load orders from Firebase
async function loadPendingOrders(){
  var fbUrl = getFirebaseUrl();
  if(!fbUrl) return ld('bb_pending_orders',[]);
  try{
    var res = await fetch(fbUrl + '/orders.json?t=' + Date.now());
    if(!res.ok){
      console.log('BoloBill: Firebase load failed:', res.status, res.statusText, fbUrl);
      return ld('bb_pending_orders',[]);
    }
    var data = await res.json();
    if(Array.isArray(data)){
      sv('bb_pending_orders', data);
      return data;
    }
    // null means empty database — that's fine
    if(data === null) return [];
    return ld('bb_pending_orders',[]);
  }catch(e){
    console.log('BoloBill: Firebase load error:', e.message);
    return ld('bb_pending_orders',[]);
  }
}


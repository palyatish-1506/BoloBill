function shareWhatsApp(){
  if(!orderItems.length){setW('No items in bill to share.','err');return;}
  const p=ld('bb_profile',DEFAULT_PROFILE);
  const billNo=document.getElementById('billNo').textContent;
  const table=document.getElementById('tableNo').value;
  const waiter=document.getElementById('waiterName').value;
  const covers=document.getElementById('covers').value||'1';
  const now=new Date();
  const t=ld('bb_tax',{cgst:2.5,sgst:2.5});
  const sub=orderItems.reduce((s,i)=>s+i.qty*i.price,0);
  const cgstAmt=(sub*parseFloat(t.cgst)/100).toFixed(2);
  const sgstAmt=(sub*parseFloat(t.sgst)/100).toFixed(2);
  const grand=(sub+parseFloat(cgstAmt)+parseFloat(sgstAmt)).toFixed(2);

  const line='━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━';
  const thin='──────────────────────────────';
  const center=(str,w=30)=>{const pad=Math.max(0,Math.floor((w-str.length)/2));return ' '.repeat(pad)+str;};
  const itemRows=orderItems.map(i=>{
    const left=i.qty+'x '+i.name;
    const right='₹'+(i.qty*i.price);
    const dots='.'.repeat(Math.max(1,30-left.length-right.length));
    return left+dots+right;
  }).join('\n');

  // Try to get customer phone from pending orders for this table
  const allOrders=ld('bb_pending_orders',[]);
  const tableOrder=allOrders.find(o=>o.table===table&&o.customerPhone);
  const customerPhone=tableOrder?tableOrder.customerPhone:'';
  const customerName=tableOrder?tableOrder.customerName:'';

  const greeting=customerName?'Hi *'+customerName+'*! 👋\nHere is your bill.\n\n':'';

  const msg=greeting+
    line+'\n'+
    center(p.name.toUpperCase())+'\n'+
    center(p.addr)+'\n'+
    center(p.city)+'\n'+
    (p.phone?center('Ph: '+p.phone)+'\n':'')+
    (p.gstin?center('GSTIN: '+p.gstin)+'\n':'')+
    line+'\n'+
    '        *TAX INVOICE*\n'+
    thin+'\n'+
    'Bill No : *'+billNo+'*\n'+
    'Date    : '+now.toLocaleDateString('en-IN')+'\n'+
    'Time    : '+now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})+'\n'+
    'Table   : '+table+' | Covers: '+covers+'\n'+
    'Waiter  : '+waiter+'\n'+
    thin+'\n'+
    '*ITEM               QTY  AMOUNT*\n'+
    thin+'\n'+
    itemRows+'\n'+
    thin+'\n'+
    'Subtotal          ₹'+sub+'\n'+
    'CGST @'+t.cgst+'%          ₹'+cgstAmt+'\n'+
    'SGST @'+t.sgst+'%          ₹'+sgstAmt+'\n'+
    line+'\n'+
    '*TOTAL AMOUNT     ₹'+grand+'*\n'+
    line+'\n'+
    center('Thank you for visiting!')+'\n'+
    center('Please visit again 🙏')+'\n'+
    line+'\n'+
    '_Powered by BoloBill — Voice Billing_';

  // If we have customer's phone, send directly to them
  var url;
  if(customerPhone){
    var phone='91'+customerPhone.replace(/\D/g,'');
    url='https://wa.me/'+phone+'?text='+encodeURIComponent(msg);
  } else {
    url='https://wa.me/?text='+encodeURIComponent(msg);
  }
  window.open(url,'_blank');
  logActivity('bill','Bill Shared','Bill '+billNo+' shared via WhatsApp'+(customerPhone?' to '+customerPhone:''),'💬');
}


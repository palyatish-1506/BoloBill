// ════════════════════════════════
let sessionTimerInterval=null;
function startSessionTimer(){
  document.getElementById('timeoutBar').style.display='block';
  resetIdleTimer();
  sessionTimerInterval=setInterval(updateSessionTime,1000);
  ['click','keydown','touchstart'].forEach(e=>document.addEventListener(e,resetIdleTimer));
}

function resetIdleTimer(){
  clearTimeout(idleTimer);
  idleTimer=setTimeout(()=>{logActivity('warning','Auto Logout',currentUser.name+' session timed out after 30 minutes','⏱️');logout();},SESSION_TIMEOUT);
  const pct=100;
  document.getElementById('timeoutFill').style.width=pct+'%';
}

function updateSessionTime(){
  if(!sessionStart)return;
  const diff=Math.floor((new Date()-sessionStart)/1000);
  const m=Math.floor(diff/60),s=diff%60;
  document.getElementById('sessionTime').textContent='Session: '+m+'m '+s+'s';
  const remaining=Math.max(0,(SESSION_TIMEOUT/1000)-diff);
  const pct=(remaining/(SESSION_TIMEOUT/1000))*100;
  document.getElementById('timeoutFill').style.width=pct+'%';
  document.getElementById('timeoutFill').style.background=pct<20?'#D94F4F':pct<50?'#B45309':'var(--g)';
}

function logout(){
  if(currentUser)logActivity('info','Logout',currentUser.name+' logged out','👋');
  clearInterval(sessionTimerInterval);clearTimeout(idleTimer);
  currentRole=null;currentUser=null;sessionStart=null;
  ['click','keydown','touchstart'].forEach(e=>document.removeEventListener(e,resetIdleTimer));
  document.getElementById('mainApp').style.display='none';
  document.getElementById('loginScreen').style.display='flex';
  document.getElementById('nav-manager').classList.add('hidden');
  document.getElementById('nav-log').classList.add('hidden');
  document.getElementById('nav-waiter').classList.remove('hidden');
  document.getElementById('clearHistBtn').style.display='none';
  goBack();clearOrder();
  document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
  document.getElementById('tab-waiter').classList.add('active');
  document.querySelectorAll('.nav-btn:not(.hidden)').forEach((x,i)=>{x.classList.remove('active');if(i===0)x.classList.add('active');});
}


function generateTableQRs(){
  var countEl=document.getElementById('qrTableCount');
  var prefixEl=document.getElementById('qrTablePrefix');
  var urlEl=document.getElementById('qrSiteUrl');

  var count=parseInt((countEl&&countEl.value)||'10');
  var prefix=(prefixEl&&prefixEl.value)||'T-';
  var baseUrl=(urlEl&&urlEl.value.trim())||window.location.href.split('?')[0];

  // Clamp count
  if(count<1)count=1;
  if(count>50)count=50;

  var tables=[];
  for(var n=1;n<=count;n++){
    tables.push(prefix+String(n).padStart(2,'0'));
  }

  var grid=document.getElementById('qrCodesGrid');
  grid.innerHTML='';

  tables.forEach(function(table){
    var tableUrl=baseUrl+'?table='+encodeURIComponent(table);

    var div=document.createElement('div');
    div.style.cssText='background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:12px;text-align:center';

    var qrDiv=document.createElement('div');
    qrDiv.style.cssText='display:flex;justify-content:center;margin-bottom:8px';
    qrDiv.id='qrdiv-'+table.replace(/[^a-z0-9]/gi,'');

    var label=document.createElement('div');
    label.style.cssText='font-size:13px;font-weight:700;color:#fff;margin-bottom:2px';
    label.textContent=table;

    var sub=document.createElement('div');
    sub.style.cssText='font-size:9px;color:rgba(255,255,255,.35)';
    sub.textContent='Scan to order';

    div.appendChild(qrDiv);div.appendChild(label);div.appendChild(sub);
    grid.appendChild(div);

    (function(el, url){
      setTimeout(function(){
        try{
          new QRCode(el,{
            text:url,
            width:120,
            height:120,
            colorDark:'#000000',
            colorLight:'#ffffff',
            correctLevel:QRCode.CorrectLevel.M
          });
        }catch(e){
          el.innerHTML='<div style="width:120px;height:120px;background:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;color:#333;text-align:center;padding:8px;border-radius:6px">'+url.substring(0,40)+'...</div>';
        }
      },50);
    })(qrDiv, tableUrl);
  });

  // Print button
  var printBtn=document.createElement('button');
  printBtn.className='btn btn-g';
  printBtn.style.cssText='width:100%;justify-content:center;margin-top:8px';
  printBtn.textContent='🖨️ Print All QR Codes';
  printBtn.onclick=function(){printTableQRs();};
  grid.appendChild(printBtn);

  logActivity('info','QR Codes Generated',count+' table QR codes generated','📱');
}


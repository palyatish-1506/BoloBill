<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BoloBill — Voice Billing System</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Plus Jakarta Sans',system-ui,sans-serif;background:#1C1B18;color:#1C1B18;min-height:100vh}
:root{
  --g:#1D9E75;--gd:#0F6E56;--gl:#D6F5EB;--g2:#E8FAF3;
  --r:#D94F4F;--rl:#FDEAEA;
  --b:#2563B0;--bl:#E8F0FD;
  --a:#B45309;--al:#FEF3C7;
  --card:#FFFFFF;--border:#E2E0D8;--border2:#D0CEC4;
  --text:#1C1B18;--muted:#6B6960;--hint:#A8A69E;
  --r8:8px;--r12:12px;--r16:16px;
}

/* ══ LOGIN SCREEN ══ */
#loginScreen{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  background:var(--text);position:relative;overflow:hidden;padding:1rem;
}
#loginScreen::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 20% 50%,rgba(29,158,117,.18) 0%,transparent 60%),
             radial-gradient(ellipse at 80% 20%,rgba(29,158,117,.1) 0%,transparent 50%),
             radial-gradient(ellipse at 60% 80%,rgba(255,255,255,.03) 0%,transparent 40%);
}
.login-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:0;max-width:900px;width:100%;
  background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);
  border-radius:24px;overflow:hidden;backdrop-filter:blur(10px);
  position:relative;z-index:1;
}
@media(max-width:640px){.login-grid{grid-template-columns:1fr}}
.login-left{
  background:linear-gradient(145deg,rgba(29,158,117,.2),rgba(29,158,117,.05));
  padding:3rem 2.5rem;display:flex;flex-direction:column;justify-content:space-between;
  border-right:1px solid rgba(255,255,255,.07);
}
.login-right{padding:3rem 2.5rem;display:flex;flex-direction:column;justify-content:center}
.brand-logo{width:56px;height:56px;background:var(--g);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:26px;margin-bottom:1.5rem;box-shadow:0 8px 24px rgba(29,158,117,.4)}
.brand-name{font-size:32px;font-weight:800;color:#fff;letter-spacing:-.5px;margin-bottom:6px}
.brand-sub{font-size:13px;color:rgba(255,255,255,.45);font-weight:500;margin-bottom:2rem}
.feature-list{display:flex;flex-direction:column;gap:12px}
.feat{display:flex;align-items:center;gap:10px}
.feat-icon{width:32px;height:32px;background:rgba(29,158,117,.2);border:1px solid rgba(29,158,117,.3);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.feat-text{font-size:12px;color:rgba(255,255,255,.55);font-weight:500;line-height:1.4}
.feat-text strong{color:rgba(255,255,255,.85);display:block;font-size:13px}
.login-footer{margin-top:2rem;font-size:11px;color:rgba(255,255,255,.25);font-weight:500}

/* Role selector */
.role-title{font-size:13px;font-weight:700;color:rgba(255,255,255,.4);letter-spacing:.8px;text-transform:uppercase;margin-bottom:1rem}
.roles{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:1.5rem}
.role-card{padding:16px 14px;border-radius:var(--r12);border:1.5px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);cursor:pointer;transition:all .2s;text-align:center}
.role-card:hover{border-color:rgba(29,158,117,.5);background:rgba(29,158,117,.08)}
.role-card.selected{border-color:var(--g);background:rgba(29,158,117,.15);box-shadow:0 0 0 3px rgba(29,158,117,.15)}
.role-icon{font-size:24px;margin-bottom:8px}
.role-name{font-size:13px;font-weight:700;color:#fff}
.role-desc{font-size:11px;color:rgba(255,255,255,.4);margin-top:3px}

/* PIN pad */
.pin-section{display:none}
.pin-section.show{display:block}
.pin-label{font-size:13px;font-weight:700;color:rgba(255,255,255,.4);letter-spacing:.8px;text-transform:uppercase;margin-bottom:8px}
.pin-who{font-size:15px;font-weight:700;color:#fff;margin-bottom:1rem}
.pin-display{display:flex;gap:10px;justify-content:center;margin-bottom:1.5rem}
.pin-dot{width:14px;height:14px;border-radius:50%;border:2px solid rgba(255,255,255,.3);background:transparent;transition:all .2s}
.pin-dot.filled{background:var(--g);border-color:var(--g);box-shadow:0 0 8px rgba(29,158,117,.5)}
.pin-dot.error{background:var(--r);border-color:var(--r)}
.numpad{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;max-width:240px;margin:0 auto}
.nkey{padding:16px;border-radius:var(--r12);border:1.5px solid rgba(255,255,255,.1);background:rgba(255,255,255,.05);cursor:pointer;font-size:18px;font-weight:700;color:#fff;transition:all .15s;font-family:inherit;text-align:center}
.nkey:hover{background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.25)}
.nkey:active{transform:scale(.94);background:rgba(29,158,117,.3)}
.nkey.del{font-size:14px;color:rgba(255,255,255,.5)}
.nkey.zero{grid-column:2}
.pin-error{font-size:12px;color:#F87171;text-align:center;margin-top:10px;font-weight:600;min-height:18px}
.lockout-msg{font-size:13px;color:#F87171;text-align:center;padding:12px;background:rgba(217,79,79,.1);border:1px solid rgba(217,79,79,.2);border-radius:var(--r8);margin-top:10px;font-weight:600}

/* ══ MAIN APP ══ */
.app{max-width:880px;margin:0 auto;padding:1.5rem 1rem 4rem;position:relative;z-index:1}
#mainApp{display:none;min-height:100vh;background:#1C1B18;position:relative}
#mainApp::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 15% 40%,rgba(29,158,117,.13) 0%,transparent 55%),radial-gradient(ellipse at 85% 15%,rgba(29,158,117,.08) 0%,transparent 50%),radial-gradient(ellipse at 60% 85%,rgba(29,158,117,.06) 0%,transparent 45%);pointer-events:none;z-index:0}
.header{background:var(--text);border-radius:var(--r16);padding:1.75rem 2rem;margin-bottom:1.25rem;position:relative;overflow:hidden}
.header::after{content:'';position:absolute;top:-60px;right:-60px;width:220px;height:220px;background:radial-gradient(circle,rgba(29,158,117,.22) 0%,transparent 70%);pointer-events:none}
.hbrand{display:flex;align-items:center;justify-content:space-between}
.hbrand-left{display:flex;align-items:center;gap:14px}
.hlogo{width:46px;height:46px;background:var(--g);border-radius:var(--r12);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
.hname{font-size:26px;font-weight:800;color:#fff;letter-spacing:-.5px;line-height:1}
.htag{font-size:12px;color:rgba(255,255,255,.45);margin-top:3px;font-weight:500}
.session-info{text-align:right}
.session-role{font-size:11px;color:rgba(255,255,255,.35);font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.session-name{font-size:14px;font-weight:700;color:#fff;margin-top:2px}
.session-time{font-size:11px;color:rgba(255,255,255,.3);margin-top:2px}
.hstats{display:flex;gap:10px;margin-top:1.25rem;flex-wrap:wrap}
.hstat{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:var(--r8);padding:10px 16px;min-width:90px}
.hstat-v{font-size:18px;font-weight:700;color:#fff}
.hstat-l{font-size:11px;color:rgba(255,255,255,.4);margin-top:2px;font-weight:500}
.nav{display:flex;gap:4px;margin-bottom:1.25rem;background:rgba(255,255,255,.05);padding:5px;border-radius:var(--r12);border:1px solid rgba(255,255,255,.1)}
.nav-btn{flex:1;padding:10px 8px;border:none;background:transparent;cursor:pointer;border-radius:var(--r8);font-size:13px;font-weight:600;color:rgba(255,255,255,.4);transition:all .18s;font-family:inherit}
.nav-btn:hover{background:rgba(255,255,255,.08);color:rgba(255,255,255,.85)}
.nav-btn.active{background:var(--g);color:#fff;box-shadow:0 2px 10px rgba(29,158,117,.3)}
.nav-btn.hidden{display:none}
.tab{display:none}.tab.active{display:block}
.card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:var(--r16);padding:1.5rem;margin-bottom:1rem;backdrop-filter:blur(8px)}
.card-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem}
.card-title{font-size:14px;font-weight:700;color:rgba(255,255,255,.9);display:flex;align-items:center;gap:8px}
.cicon{width:30px;height:30px;border-radius:var(--r8);display:flex;align-items:center;justify-content:center;font-size:15px}
.mic-area{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:var(--r12);padding:2rem 1rem;display:flex;flex-direction:column;align-items:center;gap:14px;margin-bottom:1rem}
.mic-btn{width:80px;height:80px;border-radius:50%;border:none;background:var(--g);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:transform .15s,background .2s;box-shadow:0 6px 20px rgba(29,158,117,.35)}
.mic-btn:hover{transform:scale(1.06)}
.mic-btn.rec{background:var(--r);animation:pulse 1.4s ease-out infinite}
.mic-btn svg{width:32px;height:32px;fill:white}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(217,79,79,.5)}70%{box-shadow:0 0 0 20px rgba(217,79,79,0)}100%{box-shadow:0 0 0 0 rgba(217,79,79,0)}}
.mic-lbl{font-size:13px;color:rgba(255,255,255,.5);font-weight:600}
.mic-hint{font-size:11px;color:rgba(255,255,255,.3);text-align:center;max-width:280px;line-height:1.5}
.inp{width:100%;padding:10px 14px;border:1.5px solid rgba(255,255,255,.12);border-radius:var(--r8);font-size:13px;background:rgba(255,255,255,.07);color:#fff;font-family:inherit;transition:all .15s}
.inp:focus{outline:none;border-color:var(--g);background:rgba(255,255,255,.1);box-shadow:0 0 0 3px rgba(29,158,117,.15)}
.inp::placeholder{color:rgba(255,255,255,.25)}
select.inp{cursor:pointer}
select.inp option{background:#2a2a27;color:#fff}
textarea.inp{resize:vertical;min-height:60px}
.field{margin-bottom:12px}
.field label{display:block;font-size:11px;font-weight:700;color:rgba(255,255,255,.35);margin-bottom:5px;text-transform:uppercase;letter-spacing:.5px}
.btn{padding:10px 18px;border-radius:var(--r8);border:1.5px solid rgba(255,255,255,.15);background:rgba(255,255,255,.07);cursor:pointer;font-size:13px;font-weight:600;color:rgba(255,255,255,.8);transition:all .15s;font-family:inherit;display:inline-flex;align-items:center;gap:6px}
.btn:hover{background:rgba(255,255,255,.13);border-color:rgba(255,255,255,.25)}
.btn:active{transform:scale(.98)}
.btn-g{background:var(--g);color:#fff;border-color:var(--g);box-shadow:0 2px 8px rgba(29,158,117,.25)}
.btn-g:hover{background:var(--gd);border-color:var(--gd)}
.btn-dark{background:rgba(255,255,255,.12);color:#fff;border-color:rgba(255,255,255,.2)}
.btn-dark:hover{background:rgba(255,255,255,.18)}
.btn-r{border-color:var(--r);color:var(--r);background:transparent}
.btn-r:hover{background:var(--rl)}
.btn-b{border-color:var(--b);color:var(--b);background:transparent}
.btn-b:hover{background:var(--bl)}
.btn-sm{padding:7px 12px;font-size:12px}
.btn-xs{padding:4px 9px;font-size:11px}
.btns{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}
.status{font-size:12px;min-height:20px;margin-top:8px;text-align:center;font-weight:600}
.status.ok{color:var(--g)}.status.err{color:var(--r)}.status.info{color:var(--b)}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
@media(max-width:580px){.g2,.g3{grid-template-columns:1fr}}
.bt{width:100%;border-collapse:collapse;font-size:13px}
.bt thead{background:rgba(255,255,255,.06)}
.bt th{text-align:left;font-size:10px;font-weight:700;color:rgba(255,255,255,.35);padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.08);text-transform:uppercase;letter-spacing:.5px}
.bt td{padding:10px;border-bottom:1px solid rgba(255,255,255,.05);color:rgba(255,255,255,.85);vertical-align:middle}
.bt tbody tr:hover{background:rgba(255,255,255,.04)}
.bt tr:last-child td{border-bottom:none}
.qc{display:flex;align-items:center;gap:6px;justify-content:center}
.qb{width:26px;height:26px;border-radius:50%;border:1.5px solid rgba(255,255,255,.2);background:rgba(255,255,255,.07);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;color:#fff;line-height:1;transition:all .12s;font-weight:700}
.qb:hover{background:var(--g);color:#fff;border-color:var(--g)}
.rb{background:none;border:none;cursor:pointer;color:rgba(255,255,255,.25);font-size:18px;padding:0 4px;transition:color .12s}
.rb:hover{color:var(--r)}
.tots{margin-top:14px;border-top:1px solid rgba(255,255,255,.1);padding-top:14px}
.tr-row{display:flex;justify-content:space-between;font-size:13px;padding:4px 0;color:rgba(255,255,255,.45)}
.tr-row span:last-child{font-family:'JetBrains Mono',monospace;font-size:12px}
.tr-row.grand{font-size:18px;font-weight:800;color:#fff;margin-top:10px;padding-top:12px;border-top:1px solid rgba(255,255,255,.2)}
.tr-row.grand span:last-child{font-family:'JetBrains Mono',monospace;font-size:17px;color:var(--g)}
.tr-row.tax-total{color:var(--g);font-weight:600}
.badge{display:inline-flex;align-items:center;font-size:10px;padding:3px 8px;border-radius:20px;font-weight:700}
.badge-g{background:var(--gl);color:var(--gd)}
.badge-r{background:var(--rl);color:#9B2E2E}
.badge-b{background:var(--bl);color:var(--b)}
.badge-dark{background:rgba(255,255,255,.1);color:rgba(255,255,255,.7)}
.badge-a{background:var(--al);color:var(--a)}
.mt{width:100%;border-collapse:collapse;font-size:13px}
.mt thead{background:rgba(255,255,255,.06)}
.mt th{font-size:10px;font-weight:700;color:rgba(255,255,255,.35);padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.08);text-align:left;text-transform:uppercase;letter-spacing:.5px}
.mt td{padding:7px 8px;border-bottom:1px solid rgba(255,255,255,.05);color:rgba(255,255,255,.85)}
.mt tbody tr:hover{background:rgba(255,255,255,.04)}
.mt tr:last-child td{border-bottom:none}
.mt input{width:100%;padding:6px 9px;border:1.5px solid rgba(255,255,255,.12);border-radius:6px;font-size:12px;background:rgba(255,255,255,.07);color:#fff;font-family:inherit;transition:all .12s}
.mt input:focus{outline:none;border-color:var(--g);background:rgba(255,255,255,.1)}
.hist-item{padding:14px 16px;border-radius:var(--r12);border:1px solid rgba(255,255,255,.08);margin-bottom:8px;cursor:pointer;transition:all .15s;background:rgba(255,255,255,.04)}
.hist-item:hover{border-color:rgba(29,158,117,.4);box-shadow:0 4px 16px rgba(29,158,117,.12);transform:translateY(-1px)}
.log-item{padding:10px 14px;border-radius:var(--r8);border:1px solid rgba(255,255,255,.07);margin-bottom:6px;background:rgba(255,255,255,.03);display:flex;align-items:flex-start;gap:12px}
.log-icon{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;margin-top:1px;background:rgba(255,255,255,.08)}
.bill-meta{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
.meta-pill{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:5px 12px;font-size:11px;color:rgba(255,255,255,.4);font-weight:600}
.meta-pill span{color:rgba(255,255,255,.85);margin-left:3px}
.amt-words{margin-top:12px;padding:10px 14px;background:rgba(29,158,117,.1);border:1px solid rgba(29,158,117,.25);border-radius:var(--r8);font-size:12px;color:#5DCAA5;font-weight:600;font-style:italic}
.waiter-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:var(--r12);padding:14px 16px;display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;transition:all .15s}
.waiter-card:hover{border-color:rgba(29,158,117,.35);box-shadow:0 2px 10px rgba(29,158,117,.12)}
.waiter-avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--g),var(--gd));display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:800;color:#fff;flex-shrink:0}
.timeout-bar{height:3px;background:rgba(255,255,255,.1);border-radius:2px;margin-top:1rem;overflow:hidden;display:none}
.timeout-fill{height:100%;background:var(--g);border-radius:2px;transition:width 1s linear}
@media print{
  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important;box-sizing:border-box}
  body{background:#fff!important;color:#000!important;margin:0;padding:0}
  #loginScreen,#mainApp{display:none!important}
  #printWrapper{display:block!important}
  @page{size:A4;margin:0}
}
#printWrapper{display:none}

/* ── PROFESSIONAL BILL STYLES ── */
.bill-page{
  width:210mm;min-height:297mm;margin:0 auto;
  background:#fff;font-family:'Segoe UI',Arial,sans-serif;
  color:#111;position:relative;
  display:flex;flex-direction:column;
}
.bill-outer-border{
  border:3px solid #1D9E75;margin:8mm;flex:1;
  display:flex;flex-direction:column;position:relative;
  overflow:hidden;
}
.bill-inner-border{
  border:1px solid #1D9E75;margin:3px;flex:1;
  display:flex;flex-direction:column;
}
/* Watermark */
.bill-watermark{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-35deg);
  font-size:72px;font-weight:900;color:rgba(29,158,117,.04);
  letter-spacing:8px;white-space:nowrap;pointer-events:none;z-index:0;font-family:Arial;
}
/* Header */
.bill-header{
  background:linear-gradient(135deg,#0F6E56 0%,#1D9E75 50%,#0F6E56 100%);
  padding:16px 24px;display:flex;align-items:center;gap:20px;
  border-bottom:3px solid #0F6E56;position:relative;z-index:1;
}
.bill-logo-circle{
  width:72px;height:72px;border-radius:50%;
  background:#fff;border:3px solid rgba(255,255,255,.4);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;box-shadow:0 4px 12px rgba(0,0,0,.2);
  font-size:34px;
}
.bill-logo-svg{
  width:72px;height:72px;border-radius:50%;flex-shrink:0;
}
.bill-header-text{flex:1;color:#fff}
.bill-resto-name{font-size:24px;font-weight:900;letter-spacing:1px;text-shadow:0 2px 4px rgba(0,0,0,.2)}
.bill-resto-tag{font-size:10px;letter-spacing:3px;opacity:.75;margin-top:2px;text-transform:uppercase}
.bill-resto-addr{font-size:11px;opacity:.85;margin-top:6px;line-height:1.5}
.bill-header-right{text-align:right;color:#fff;flex-shrink:0}
.bill-inv-label{font-size:9px;letter-spacing:3px;opacity:.7;text-transform:uppercase}
.bill-inv-no{font-size:22px;font-weight:900;letter-spacing:1px}
.bill-gstin{font-size:9px;opacity:.75;margin-top:4px}

/* Meta row */
.bill-meta-row{
  display:grid;grid-template-columns:repeat(3,1fr);
  background:#F0FBF6;border-bottom:1.5px solid #1D9E75;
  position:relative;z-index:1;
}
.bill-meta-cell{
  padding:8px 16px;border-right:1px solid #b2e4d0;
}
.bill-meta-cell:last-child{border-right:none}
.bill-meta-label{font-size:8px;font-weight:700;color:#0F6E56;text-transform:uppercase;letter-spacing:.8px;margin-bottom:2px}
.bill-meta-value{font-size:12px;font-weight:700;color:#111}

/* Section heading */
.bill-section-head{
  background:#1D9E75;color:#fff;
  font-size:9px;font-weight:700;letter-spacing:1.5px;
  text-transform:uppercase;padding:5px 16px;
  position:relative;z-index:1;
}

/* Items table */
.bill-items-table{width:100%;border-collapse:collapse;position:relative;z-index:1}
.bill-items-table thead tr{background:#E8FAF3}
.bill-items-table th{
  padding:7px 10px;font-size:9px;font-weight:700;
  color:#0F6E56;text-transform:uppercase;letter-spacing:.6px;
  border-bottom:1.5px solid #1D9E75;
}
.bill-items-table td{
  padding:8px 10px;font-size:11px;
  border-bottom:1px solid #e8f5ee;color:#222;vertical-align:middle;
}
.bill-items-table tbody tr:nth-child(even){background:#f7fdfb}

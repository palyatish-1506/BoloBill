// Poll for new customer orders every 5 seconds
var seenOrderIds = null; // null = first run
var seenPaymentRequestIds = null; // track payment_requested separately

function startOrderPolling(){
  if('Notification' in window && Notification.permission === 'default'){
    Notification.requestPermission();
  }

  async function poll(){
    try{
      var fbUrl = getFirebaseUrl();
      if(!fbUrl) return;

      var res = await fetch(fbUrl + '/orders.json?t=' + Date.now());
      if(!res.ok) return;
      var all = await res.json();
      if(!Array.isArray(all)) all = [];

      // Only keep actionable orders locally — discard completed ones
      var actionableAll = all.filter(function(o){
        return o.status==='pending' || o.status==='payment_requested' || o.status==='accepted';
      });
      sv('bb_pending_orders', actionableAll);

      var pending = all.filter(function(o){ return o.status==='pending'; });
      var paymentRequested = all.filter(function(o){ return o.status==='payment_requested'; });
      var actionable = pending.concat(paymentRequested);

      // Update badge — show all actionable orders
      var badge = document.getElementById('pendingBadge');
      if(badge){
        if(actionable.length > 0){ badge.style.display='inline'; badge.textContent=actionable.length; }
        else badge.style.display='none';
      }

      // Update sync time
      var syncTime = document.getElementById('lastSyncTime');
      if(syncTime) syncTime.textContent = new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit'});

      // First run — record everything silently
      if(seenOrderIds === null){
        seenOrderIds = pending.map(function(o){ return o.id; });
        seenPaymentRequestIds = paymentRequested.map(function(o){ return o.id; });
        var tab = document.getElementById('tab-pending');
        if(tab && tab.classList.contains('active')) renderPendingOrders();
        return;
      }

      // Detect NEW pending orders
      var newOrders = pending.filter(function(o){
        return seenOrderIds.indexOf(o.id) === -1;
      });
      if(newOrders.length > 0){
        seenOrderIds = pending.map(function(o){ return o.id; });
        showNewOrderNotification(newOrders[0], newOrders.length);
        var tab = document.getElementById('tab-pending');
        if(tab && tab.classList.contains('active')) renderPendingOrders();
      } else {
        seenOrderIds = pending.map(function(o){ return o.id; });
      }

      // Detect NEW payment requests (customer tapped "Done Eating")
      var newPayReqs = paymentRequested.filter(function(o){
        return seenPaymentRequestIds.indexOf(o.id) === -1;
      });
      if(newPayReqs.length > 0){
        seenPaymentRequestIds = paymentRequested.map(function(o){ return o.id; });
        // Fire payment notification
        newPayReqs.forEach(function(o){
          showPaymentRequestNotification(o);
        });
        // Refresh orders tab
        var tab = document.getElementById('tab-pending');
        if(tab && tab.classList.contains('active')) renderPendingOrders();
      } else {
        seenPaymentRequestIds = paymentRequested.map(function(o){ return o.id; });
      }

    }catch(e){
      var syncTime = document.getElementById('lastSyncTime');
      if(syncTime) syncTime.textContent = 'Reconnecting...';
    }
  }

  poll();
  var pollInterval = setInterval(poll, 4000);

  // KEY FIX: When tab comes back from sleep/background — poll immediately
  document.addEventListener('visibilitychange', function(){
    if(document.visibilityState === 'visible'){
      poll(); // wake up and fetch fresh data right away
    }
  });

  // Also poll on any user interaction (click, scroll) after being idle
  var lastActivity = Date.now();
  document.addEventListener('click', function(){
    if(Date.now() - lastActivity > 10000){ // inactive for 10+ seconds
      poll();
    }
    lastActivity = Date.now();
  });
}

